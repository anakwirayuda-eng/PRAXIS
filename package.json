{
  "name": "ddevmedcase",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --env-file=.env server/server.js --dev",
    "start": "node --env-file=.env server/server.js",
    "build": "vite build",
    "build:prod": "vite build && node scripts/obfuscate-dist.js && node scripts/split-cases.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "pipeline": "node ingestion/pipeline.js all",
    "pipeline:fetch": "node ingestion/pipeline.js fetch",
    "pipeline:compile": "node ingestion/pipeline.js compile",
    "pipeline:deploy": "node ingestion/pipeline.js deploy",
    "pipeline:status": "node ingestion/pipeline.js status",
    "pipeline:dry": "node ingestion/pipeline.js all --dry-run",
    "backup:db": "node scripts/backup-db.js",
    "deploy:worker": "npx wrangler deploy",
    "dev:worker": "npx wrangler dev",
    "db:migrate": "npx wrangler d1 migrations apply praxis_db --remote",
    "db:migrate:local": "npx wrangler d1 migrations apply praxis_db --local"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "adm-zip": "^0.5.16",
    "framer-motion": "^12.36.0",
    "hono": "^4.12.8",
    "isomorphic-dompurify": "^3.5.1",
    "lucide-react": "^0.577.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "mammoth": "^1.12.0",
    "parquet-wasm": "^0.7.1",
    "pdfjs-dist": "^4.10.38",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.1.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0"
  }
}
